# Optional: Set custom port
# PORT=8082

# Optional: Set number of pooled clients
# POOL_SIZE=3

# Optional: Set request timeout in seconds
# CLAUDE_TIMEOUT=120

# Optional: Set Codex request timeout in seconds (defaults to CLAUDE_TIMEOUT)
# CODEX_TIMEOUT=120

# Optional: Override the Codex CLI model used by the "codex" alias
# CODEX_MODEL=gpt-5.4-mini

# Optional: Skip Claude SDK pool pre-warm on startup
# AGENTBRIDGE_PREWARM_CLAUDE=0
